#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UPLOAD_FILE=

usage() {
  echo "$0 <artist> [file...]" >&2
  exit 1
}

# shellcheck source=/dev/null
source "$ROOT_DIR/utils/source.sh"
source_modules \
  utils/db.sh \
  utils/profile.sh \
  utils/object.sh \
  utils/image.sh \
  utils/sequence.sh \
  utils/archive.sh

add_file() {
  local artist
  local input
  local mime
  artist=$1
  input=$2
  if [ ! -f "$input" ] || [ ! -r "$input" ]; then
    echo "input is not a readable file: $input" >&2
    return 1
  fi
  mime=$(file -b --mime-type -- "$input")
  case "$mime" in
    application/zip | application/x-zip | application/x-zip-compressed)
      archive_add "$artist" "$input"
      ;;
    *) image_add "$artist" "$input" ;;
  esac
}

main() {
  local artist
  local input
  [ "$#" -ge 1 ] || usage
  artist=$1
  shift
  profile_prepare
  if [ "$#" -gt 0 ]; then
    for input in "$@"; do
      add_file "$artist" "$input"
    done
    return 0
  fi
  UPLOAD_FILE=$(mktemp "$ARTS_STATE_DIR/.upload.XXXXXX")
  trap 'rm -f "$UPLOAD_FILE"' EXIT HUP INT TERM
  cat >"$UPLOAD_FILE"
  add_file "$artist" "$UPLOAD_FILE"
}

main "$@"
